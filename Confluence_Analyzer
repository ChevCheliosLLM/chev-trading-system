        return base64.b64encode(buf.getvalue()).decode("utf-8")


async def analyze_confluence(
    self,
    symbol: str,
    primary_timeframe: str = "1h",
    zoom_candles: int = 300,
    __event_emitter__=None,
) -> str:
    """
    Scans 15m, 30m, 1h, and 4h timeframes using Kev's validated-instance model.
    Tier A: level validated across ALL timeframes simultaneously (15m>=5, 30m>=3, 1h>=2, 4h>=2).
    Tier B: single-TF fallback near current price so the chart is never empty.
    Also detects the active auction (balance zone), anchors VP and Fibonacci to the impulse
    that created the auction, computes market direction and participation, and annotates
    the output with auction-level confluence (VAH/VAL vs S/R alignment).
    :param symbol: e.g. SOLUSDT, BTCUSDT
    :param primary_timeframe: Timeframe for chart display, volume trend, and Fib reference (default 1h)
    :param zoom_candles: Candles to display — lower zooms in, higher zooms out (default 300)
    """
    try:
        timeframes = ["15m", "30m", "1h", "4h"]
        resistance_touches_by_tf, support_touches_by_tf = {}, {}
        primary_df = None

        for tf in timeframes:
            df = self._fetch_candles(symbol, tf, limit=700)
            if tf == primary_timeframe:
                primary_df = df
            touches = self._get_timed_touches(df)
            resistance_touches_by_tf[tf] = [(ts, p) for ts, p, k in touches if k == "resistance"]
            support_touches_by_tf[tf]    = [(ts, p) for ts, p, k in touches if k == "support"]

        # BUG FIX: primary_df is set inside the loop above; this is the fallback only
        if primary_df is None:
            primary_df = self._fetch_candles(symbol, primary_timeframe, limit=700)

        # ── Analysis begins here (was mistakenly inside `if primary_df is None:`) ──
        current_price = primary_df["close"].iloc[-1]

        resistance_levels = self._build_validated_levels(resistance_touches_by_tf, "resistance")
        support_levels    = self._build_validated_levels(support_touches_by_tf,    "support")

        resistance_zones = [z for z in resistance_levels if z["price"] > current_price]
        support_zones    = [z for z in support_levels    if z["price"] < current_price]

        tier_b_resistance = [z for z in self._build_single_tf_levels(resistance_touches_by_tf[primary_timeframe]) if z["price"] > current_price]
        tier_b_support    = [z for z in self._build_single_tf_levels(support_touches_by_tf[primary_timeframe])    if z["price"] < current_price]

        top_resistance = self._pick_nearest_level(current_price, resistance_zones, tier_b_resistance, primary_timeframe)
        top_support    = self._pick_nearest_level(current_price, support_zones,    tier_b_support,    primary_timeframe)

        vol_trend = self._volume_trend(primary_df)

        fib_lookback = min(zoom_candles, 300)
        fib_levels_dict, fib_direction, fib_origin_high, fib_origin_low = (
            self._fib_from_real_impulse(primary_df, lookback=fib_lookback)
        )

        def near_other_signals(price):
            agree, near = 0, []
            if top_resistance and abs(price - top_resistance["price"]) / price * 100 <= 1.5:
                agree += 1; near.append("resistance zone")
            if top_support    and abs(price - top_support["price"])    / price * 100 <= 1.5:
                agree += 1; near.append("support zone")
            for name, fib_price in fib_levels_dict.items():
                if abs(price - fib_price) / price * 100 <= 1.5:
                    agree += 1; near.append(f"Fibonacci {name}"); break
            return agree, near

        chart_df      = self._add_indicators(self._fetch_candles(symbol, primary_timeframe, limit=zoom_candles))
        display_low   = chart_df["low"].min()
        display_high  = chart_df["high"].max()

        draw_zones = []
        drawn_prices = set()
        for r_lvl in resistance_zones:
            if display_low <= r_lvl["price"] <= display_high:
                p = r_lvl["price"]; pad = p * 0.0025
                draw_zones.append((p, p + pad, p - pad, f"R: {r_lvl['instances']}x validated (multi-TF)", "#f23645"))
                drawn_prices.add(round(p, 4))
        for s_lvl in support_zones:
            if display_low <= s_lvl["price"] <= display_high:
                p = s_lvl["price"]; pad = p * 0.0025
                draw_zones.append((p, p + pad, p - pad, f"S: {s_lvl['instances']}x validated (multi-TF)", "#089981"))
                drawn_prices.add(round(p, 4))
        if top_resistance and round(top_resistance["price"], 4) not in drawn_prices:
            p = top_resistance["price"]; pad = p * 0.0025
            draw_zones.append((p, p + pad, p - pad, f"R: {top_resistance['label']}", "#f23645"))
        if top_support and round(top_support["price"], 4) not in drawn_prices:
            p = top_support["price"]; pad = p * 0.0025
            draw_zones.append((p, p + pad, p - pad, f"S: {top_support['label']}", "#089981"))

        img_b64 = self._render_analysis_chart(
            chart_df, symbol, primary_timeframe, draw_zones,
            fib_levels_dict, fib_origin_high, fib_origin_low,
        )

        if __event_emitter__:
            await __event_emitter__({
                "type": "files",
                "data": {"files": [{"type": "image", "url": f"data:image/png;base64,{img_b64}"}]},
            })

        # ── Auction detection (inline swing->leg->balance) ────────────────────
        n     = len(primary_df)
        raw_h = primary_df["high"].values.astype(float)
        raw_l = primary_df["low"].values.astype(float)
        raw_c = primary_df["close"].values.astype(float)
        raw_o = primary_df["open"].values.astype(float)
        raw_v = primary_df["volume"].values.astype(float) if "volume" in primary_df.columns else np.ones(n)

        prev_c = np.roll(raw_c, 1); prev_c[0] = raw_c[0]
        tr_v   = np.maximum(raw_h - raw_l, np.maximum(np.abs(raw_h - prev_c), np.abs(raw_l - prev_c)))
        atr_v  = np.zeros(n); atr_v[0] = tr_v[0]; alpha_a = 1.0 / 14
        for k in range(1, n): atr_v[k] = alpha_a * tr_v[k] + (1 - alpha_a) * atr_v[k - 1]
        atr_now = float(atr_v[-1]) if atr_v[-1] > 0 else 1e-6

        wn, cw = 3, 8
        raw_sw = []
        for i in range(wn, n - cw):
            if all(raw_h[i] >= raw_h[i - j] for j in range(1, wn + 1)) and all(raw_h[i] >= raw_h[i + j] for j in range(1, cw + 1)):
                raw_sw.append((i, raw_h[i], "H"))
            if all(raw_l[i] <= raw_l[i - j] for j in range(1, wn + 1)) and all(raw_l[i] <= raw_l[i + j] for j in range(1, cw + 1)):
                raw_sw.append((i, raw_l[i], "L"))
        raw_sw.sort(key=lambda x: x[0])
        sw = []
        for s in raw_sw:
            if not sw: sw.append(s); continue
            if s[2] == sw[-1][2]:
                if s[2] == "H" and s[1] >= sw[-1][1]: sw[-1] = s
                elif s[2] == "L" and s[1] <= sw[-1][1]: sw[-1] = s
            else: sw.append(s)

        avg_vol = float(raw_v.mean()) if raw_v.mean() > 0 else 1.0
        legs = []
        for i in range(len(sw) - 1):
            i0, p0, _ = sw[i]; i1, p1, _ = sw[i + 1]
            atr_at  = float(atr_v[min(i0, n - 1)])
            dist_a  = abs(p1 - p0) / max(atr_at, 1e-10)
            bc      = max(1, i1 - i0)
            bodies  = np.abs(raw_c[i0:i1+1] - raw_o[i0:i1+1])
            ranges  = np.maximum(raw_h[i0:i1+1] - raw_l[i0:i1+1], 1e-10)
            br      = float(np.mean(bodies / ranges))
            vexp    = float(raw_v[i0:i1+1].mean()) / max(avg_vol, 1e-10)
            spdn    = min(1.0, (abs(p1 - p0) / max(p0, 1e-10) * 100.0 / bc) / 0.4)
            energy  = min(1.0, spdn * 0.4 + br * 0.4 + min(1.0, vexp / 1.5) * 0.2)
            if   dist_a >= 2.0 and energy >= 0.55: char = "IMPULSIVE"
            elif dist_a <= 1.0 or  energy <= 0.35: char = "CORRECTIVE"
            else:                                   char = "NEUTRAL"
            legs.append({"i0": i0, "p0": p0, "i1": i1, "p1": p1,
                         "direction": "UP" if p1 > p0 else "DOWN",
                         "dist_atr": dist_a, "energy": energy, "character": char})

        bal_legs = []
        for leg in reversed(legs[-8:]):
            if leg["character"] in ("CORRECTIVE", "NEUTRAL") or leg["energy"] < 0.5:
                bal_legs.insert(0, leg)
            else: break

        if len(bal_legs) >= 2:
            bal_high       = max(max(l["p0"], l["p1"]) for l in bal_legs)
            bal_low        = min(min(l["p0"], l["p1"]) for l in bal_legs)
            anchor_bar     = bal_legs[0]["i0"]
            auction_reason = f"Balance zone — {len(bal_legs)} corrective legs"
        elif legs:
            last           = legs[-1]
            bal_high, bal_low = max(last["p0"], last["p1"]), min(last["p0"], last["p1"])
            anchor_bar     = last["i0"]
            auction_reason = "No balance — using last leg range"
        else:
            bal_high       = float(primary_df["high"].iloc[-20:].max())
            bal_low        = float(primary_df["low"].iloc[-20:].min())
            anchor_bar     = max(0, n - 20)
            auction_reason = "No legs detected — using recent range"

        bal_width_atr = (bal_high - bal_low) / max(atr_now, 1e-10)
        anchor_price  = (bal_high + bal_low) / 2.0
        auction_age   = n - 1 - anchor_bar
        maturity      = round(min(1.0, auction_age / 30.0), 2)

        imp_anchor = None
        for leg in reversed(legs):
            if leg["i1"] <= anchor_bar and leg["character"] == "IMPULSIVE":
                imp_anchor = leg; break

        # VP anchored to the auction window
        vp_poc = vp_vah = vp_val = None
        seg = primary_df.iloc[max(0, anchor_bar):]
        if len(seg) >= 5:
            sh = float(seg["high"].max()); sl = float(seg["low"].min())
            if sh > sl:
                N = 24; bsz = (sh - sl) / N; bins_vp = np.zeros(N)
                for _, row in seg.iterrows():
                    bh, bl, bv = float(row["high"]), float(row["low"]), float(row.get("volume", 0))
                    for b in range(N):
                        blo = sl + b * bsz; bhi = blo + bsz
                        if bh >= blo and bl <= bhi:
                            bins_vp[b] += bv / max(1, int((bh - bl) / bsz + 1))
                pb = int(np.argmax(bins_vp))
                vp_poc = round(sl + (pb + 0.5) * bsz, 6)
                tot = bins_vp.sum(); tgt = tot * 0.70
                vb = hb = pb; acc = bins_vp[pb]; lo_b, hi_b = pb - 1, pb + 1
                while acc < tgt:
                    lv = bins_vp[lo_b] if lo_b >= 0 else -1.0
                    hv = bins_vp[hi_b] if hi_b < N else -1.0
                    if lv <= 0 and hv <= 0: break
                    if lv >= hv: acc += lv; vb = lo_b; lo_b -= 1
                    else:        acc += hv; hb = hi_b; hi_b += 1
                vp_vah = round(sl + (hb + 1) * bsz, 6)
                vp_val = round(sl + vb * bsz, 6)

        if   current_price > bal_high * 1.005 or current_price < bal_low * 0.995: auction_state = "INACTIVE"
        elif bal_width_atr < 0.8:                                                  auction_state = "BALANCING"
        else:                                                                       auction_state = "ACTIVE"

        rl = legs[-6:]
        dir_score = 0.0
        if rl:
            w_s = w_t = 0.0
            for leg in rl:
                sgn = 1.0 if leg["direction"] == "UP" else -1.0
                w = leg["dist_atr"] * leg["energy"]; w_s += sgn * w; w_t += w
            dir_score = round(max(-100.0, min(100.0, w_s / max(w_t, 1e-10) * 100.0)), 1)
        dir_lbl = "BULLISH" if dir_score > 30 else ("BEARISH" if dir_score < -30 else "NEUTRAL")

        # ── Output ────────────────────────────────────────────────────────────
        lines = [
            f"Chart drawn with S/R zones and Fibonacci levels.",
            f"Current price: {current_price:.6f}",
            f"",
            f"AUCTION STRUCTURE [{auction_state}] | Maturity: {maturity:.0%}:",
            f"  Balance zone : {bal_low:.6f} – {bal_high:.6f} ({bal_width_atr:.1f} ATR wide)",
            f"  Anchor price : {anchor_price:.6f} | Age: {auction_age} bars",
            f"  Leg direction: {dir_lbl} ({dir_score:+.0f}) | {len(legs)} legs | {len(sw)} swings",
            f"  Created from : {auction_reason}",
        ]
        if vp_poc:
            lines.append(f"  VP (auction) : POC={vp_poc:.6f} | VAH={vp_vah:.6f} | VAL={vp_val:.6f}")
        if imp_anchor:
            a_lo = round(min(imp_anchor["p0"], imp_anchor["p1"]), 6)
            a_hi = round(max(imp_anchor["p0"], imp_anchor["p1"]), 6)
            lines.append(f"  Impulse anchor: {a_lo:.6f} – {a_hi:.6f} (leg that created this auction)")
        lines.append("")

        lines.append(f"Volume trend (last 10 candles, {primary_timeframe}): {vol_trend}")
        lines.append(f"Fibonacci measured from the most significant recent swing ({fib_direction}):")
        for name, price in fib_levels_dict.items():
            lines.append(f"  {name}: {price:.6f}")

        if top_resistance:
            lines.append(f"\nSTRONGEST RESISTANCE: {top_resistance['price']:.6f} — {top_resistance['label']}")
            if vol_trend == "decreasing":
                lines.append("-> Volume fading into resistance: weak breakout attempt — favors SHORT/fade over chasing.")
            elif vol_trend == "increasing":
                lines.append("-> Volume building into resistance: real breakout possible if it clears with conviction.")
            for name, fib_price in fib_levels_dict.items():
                if abs(top_resistance["price"] - fib_price) / top_resistance["price"] * 100 <= 1.5:
                    lines.append(f"-> CONFLUENCE: resistance aligns with Fibonacci {name} — extra weight behind this zone.")

        if top_support:
            lines.append(f"\nSTRONGEST SUPPORT: {top_support['price']:.6f} — {top_support['label']}")
            for name, fib_price in fib_levels_dict.items():
                if abs(top_support["price"] - fib_price) / top_support["price"] * 100 <= 1.5:
                    extra = " plus fading volume" if vol_trend == "decreasing" else ""
                    lines.append(f"-> CONFLUENCE: support aligns with Fibonacci {name}{extra} — strong reversal zone if other signals agree.")

        # Auction-level confluence notes
        if vp_poc:
            if abs(current_price - vp_poc) / max(current_price, 1e-10) * 100 <= 1.0:
                lines.append(f"\nATTENTION: Price is AT the VP POC ({vp_poc:.6f}) — highest-volume agreement zone. Expect choppiness or a strong reaction here.")
            if top_support and vp_val and abs(top_support["price"] - vp_val) / max(top_support["price"], 1e-10) * 100 <= 1.5:
                lines.append(f"\nAUCTION CONFLUENCE: Support {top_support['price']:.6f} aligns with VAL {vp_val:.6f} — value area floor defended by both price structure AND volume. Elevated bounce probability.")
            if top_resistance and vp_vah and abs(top_resistance["price"] - vp_vah) / max(top_resistance["price"], 1e-10) * 100 <= 1.5:
                lines.append(f"\nAUCTION CONFLUENCE: Resistance {top_resistance['price']:.6f} aligns with VAH {vp_vah:.6f} — value area ceiling defended by both price structure AND volume. Elevated rejection probability.")

        all_extra_signals = []
        all_extra_signals.extend(self._detect_rsi_divergence(primary_df))
        all_extra_signals.extend(self._detect_rsi_divergence_forming(primary_df))

        consolidation = self._detect_consolidation_range(primary_df)
        if consolidation:
            vp = self._volume_profile(primary_df, consolidation[0], consolidation[1])
            if vp:
                all_extra_signals.append({
                    "type": "Volume Profile POC",
                    "price": vp["poc"],
                    "note": f"heaviest traded price in recent consolidation (Value Area: {vp['val']:.4f} – {vp['vah']:.4f})",
                })
                for sig in self._volume_profile_behavior_signals(primary_df, vp):
                    all_extra_signals.append(sig)

        for sig in all_extra_signals:
            agree, near = near_other_signals(sig["price"])
            if agree >= 2:
                lines.append(f"\nTRIPLE CONFLUENCE: {sig['type']} at {sig['price']:.4f} — {sig['note']}, AND lines up with {' + '.join(near)}. High-conviction zone.")

        return "\n".join(lines)
    except Exception as e:
        return f"Error analyzing confluence:\n{str(e)}\n\n{traceback.format_exc()}"
